# ── Repo ────────────────────────────────────────────────────
# OJO: GHCR exige minúsculas. Se llama GHCR_REPO (NO GITHUB_REPOSITORY)
# a propósito: GitHub Actions exporta GITHUB_REPOSITORY con mayúsculas
# y pisaría este valor en el deploy del CI.
GHCR_REPO=necro-coder/namistr
# (el runner se instala directo en el VPS, no necesita token aquí)

# ── Dominio ─────────────────────────────────────────────────
DOMAIN=tudominio.com
CF_TUNNEL_TOKEN=              # Cloudflare Zero Trust → Tunnels

# ── MediaMTX ────────────────────────────────────────────────
# (sin contraseña de publicación: el acceso al RTMP lo limita Tailscale)

# ── Twitch ──────────────────────────────────────────────────
# TWITCH_STREAM_KEY ya NO va aquí: el canvas de Twitch en OBS emite
# directo a rtmp://live.twitch.tv/app con esa key. El servidor no la usa.
TWITCH_CHANNEL=               # tu_usuario (en minúsculas)
TWITCH_CLIENT_ID=             # dev.twitch.tv → App (chat/viewers/login)
TWITCH_CLIENT_SECRET=         # dev.twitch.tv → App
# Debe coincidir EXACTO con un Redirect URL registrado en la app de Twitch:
TWITCH_REDIRECT_URI=https://necro-coder.site/auth/twitch/callback

# ── App ─────────────────────────────────────────────────────
JWT_SECRET=                   # openssl rand -hex 32
IMAGE_TAG=latest              # lo sobreescribe el CI/CD
