# ── Repo ────────────────────────────────────────────────────
# OJO: GHCR exige minúsculas. Se llama GHCR_REPO (NO GITHUB_REPOSITORY)
# a propósito: GitHub Actions exporta GITHUB_REPOSITORY con mayúsculas
# y pisaría este valor en el deploy del CI.
GHCR_REPO=necro-coder/namistr
# (el runner se instala directo en el VPS, no necesita token aquí)

# ── Dominio ─────────────────────────────────────────────────
DOMAIN=tudominio.com
CF_TUNNEL_TOKEN=              # Cloudflare Zero Trust → Tunnels

# ── MediaMTX ────────────────────────────────────────────────
MEDIAMTX_PUBLISH_PASS=        # contraseña para OBS (inventada)

# ── Twitch ──────────────────────────────────────────────────
TWITCH_STREAM_KEY=            # dashboard.twitch.tv
TWITCH_CHANNEL=               # tu_usuario
TWITCH_CLIENT_ID=             # dev.twitch.tv → App
TWITCH_CLIENT_SECRET=         # dev.twitch.tv → App

# ── App ─────────────────────────────────────────────────────
JWT_SECRET=                   # openssl rand -hex 32
IMAGE_TAG=latest              # lo sobreescribe el CI/CD
